{
  "benchmark_name": "orientation_sweep",
  "case_family": "primitive",
  "sweep_family": "orientation_sweep",
  "description": "Relative pose sweep for box-box contact with deterministic and seeded yaw samples.",
  "sdf_backends": ["analytic", "openvdb"],
  "reference_backends": ["analytic", "fcl"],
  "solver_backends": ["simple"],
  "voxel_sizes": [0.08],
  "narrow_band_half_widths": [2.0, 4.0, 8.0],
  "runtime_iterations": 16,
  "enable_solver_probe": true,
  "seed": 13,
  "orientation_axis": [0.0, 0.0, 1.0],
  "orientation_apply_to": "b",
  "orientation_yaw_degrees": [0.0, 15.0, 30.0, 45.0, 60.0, 90.0],
  "random_orientation_count": 2,
  "random_orientation_min_deg": -45.0,
  "random_orientation_max_deg": 45.0,
  "base_case": {
    "name": "box_box_orientation_base",
    "gap_axis": [1.0, 0.0, 0.0],
    "a": {
      "name": "box_a",
      "type": "box",
      "center": [0.0, 0.0, 0.0],
      "half_extents": [0.44, 0.30, 0.24],
      "rotation_rpy_deg": [0.0, 0.0, 0.0]
    },
    "b": {
      "name": "box_b",
      "type": "box",
      "center": [0.98, 0.20, 0.0],
      "half_extents": [0.40, 0.34, 0.26],
      "rotation_rpy_deg": [0.0, 0.0, 0.0]
    }
  }
}
