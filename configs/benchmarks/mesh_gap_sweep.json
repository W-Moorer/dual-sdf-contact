{
  "benchmark_name": "mesh_gap_sweep",
  "case_family": "mesh",
  "sweep_family": "gap_sweep",
  "description": "Gap sweep near narrow-band boundaries for a mesh-box benchmark pair.",
  "sdf_backends": ["analytic", "openvdb"],
  "reference_backends": ["analytic", "fcl"],
  "solver_backends": ["simple"],
  "voxel_sizes": [0.10, 0.06],
  "narrow_band_half_widths": [2.0, 4.0, 8.0],
  "runtime_iterations": 12,
  "enable_solver_probe": true,
  "seed": 29,
  "gap_values": [-0.04, -0.01, 0.00, 0.01, 0.04],
  "base_case": {
    "name": "mesh_box_gap_base",
    "gap_axis": [1.0, 0.0, 0.0],
    "a": {
      "name": "mesh_a",
      "type": "mesh",
      "center": [0.0, 0.0, 0.0],
      "rotation_rpy_deg": [0.0, 0.0, 15.0],
      "mesh_path": "../../data/meshes/unit_cube.obj",
      "mesh_scale": 0.92,
      "mesh_recenter": true,
      "mesh_normalize": false
    },
    "b": {
      "name": "box_b",
      "type": "box",
      "center": [1.25, 0.08, 0.0],
      "half_extents": [0.44, 0.32, 0.30],
      "rotation_rpy_deg": [0.0, 0.0, -10.0]
    }
  }
}
